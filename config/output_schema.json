{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CandidateProjectedOutput",
  "description": "JSON Schema for the projected output of the Candidate Data Transformer",
  "type": "object",
  "properties": {
    "candidate_name":  { "type": ["string", "null"] },
    "primary_email":   { "type": ["string", "null"], "format": "email" },
    "primary_phone":   { "type": ["string", "null"], "pattern": "^\\+[1-9]\\d{6,14}$" },
    "city":            { "type": ["string", "null"] },
    "region":          { "type": ["string", "null"] },
    "country":         { "type": ["string", "null"] },
    "headline":        { "type": ["string", "null"] },
    "top_skill":       { "type": ["string", "null"] },
    "current_company": { "type": ["string", "null"] },
    "current_title":   { "type": ["string", "null"] },
    "candidate_id":    { "type": ["string", "null"] },
    "overall_confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  },
  "additionalProperties": true
}
